# ============================================================================
# Survivor Liga MX Bot — Plantilla de configuración (.env.example)
# ----------------------------------------------------------------------------
# Copia este archivo a `.env` y rellena tus valores reales:
#     cp .env.example .env
#
# IMPORTANTE:
# - `.env` NUNCA se commitea (está en .gitignore). Solo este `.env.example`.
# - Aquí solo van PLACEHOLDERS, nunca claves reales.
# - El bot funciona en modo "ESPERAR / NO ENVIAR": no cierra ni envía picks
#   automáticamente. Telegram es opcional y solo informativo.
# - Todas las claves vacías ("") hacen que ese proveedor quede DISABLED_BY_CONFIG
#   de forma segura; el bot degrada sin romperse.
# ============================================================================

# ----------------------------------------------------------------------------
# The Odds API — momios 1X2 / totales (https://the-odds-api.com)
# ----------------------------------------------------------------------------
ODDS_API_KEY=
ODDS_API_KEY_PRIMARY=
ODDS_API_KEY_BACKUP=
ODDS_SPORT=soccer_mexico_ligamx
ODDS_REGIONS=us,eu
ODDS_MARKETS=h2h,totals
ODDS_FORMAT=decimal
# Intervalo mínimo entre sincronizaciones (minutos) para cuidar el presupuesto de API.
ODDS_SYNC_MIN_INTERVAL_MINUTES=360

# ----------------------------------------------------------------------------
# Watchdog de movimiento de mercado
# ----------------------------------------------------------------------------
ODDS_WATCHDOG_MIN_INTERVAL_MINUTES=180
ODDS_WATCHDOG_TOTALS_LINE=2.5
# 1 = permitir alertas de severidad "importante" por Telegram; 0 = solo críticas.
ODDS_WATCHDOG_TELEGRAM_IMPORTANTE=0

# ----------------------------------------------------------------------------
# API-Football — alineaciones, lesiones, fixtures (https://www.api-football.com)
# ----------------------------------------------------------------------------
APIFOOTBALL_KEY=
APIFOOTBALL_SEASON=2026
APIFOOTBALL_TIMEZONE=America/Mexico_City
# Cuántos fixtures próximos pedir.
APIFOOTBALL_NEXT=20
# Intervalo mínimo entre sincronizaciones (minutos).
APIFOOTBALL_SYNC_MIN_INTERVAL_MINUTES=720
# IDs de liga/temporada Liga MX en API-Football (defaults del proyecto).
FOOTBALL_LIGAMX_LEAGUE_ID=262
FOOTBALL_LIGAMX_SEASON=2026
FOOTBALL_LINEUPS_MAX_FIXTURES=9

# ----------------------------------------------------------------------------
# TheSportsDB — respaldo de calendario/resultados (https://www.thesportsdb.com)
# ----------------------------------------------------------------------------
# "123" es la API key pública gratuita de prueba de TheSportsDB.
THESPORTSDB_API_KEY=123
THESPORTSDB_LIGAMX_ID=4350

# ----------------------------------------------------------------------------
# Groq — IA primaria para resumen/análisis de noticias (https://groq.com)
# ----------------------------------------------------------------------------
GROQ_API_KEY=
GROQ_API_KEY_PRIMARY=
GROQ_API_KEY_BACKUP=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# Límites para no exceder el contexto / presupuesto del modelo.
GROQ_MAX_INPUT_CHARS=18000
GROQ_MAX_NOTICIAS=15
GROQ_MAX_RESUMEN_CHARS=300
GROQ_CACHE_MINUTES=360

# ----------------------------------------------------------------------------
# Google Gemini — IA secundaria (https://ai.google.dev)
# ----------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_API_KEY_BACKUP=
GEMINI_MODEL=gemini-2.5-flash

# ----------------------------------------------------------------------------
# Fireworks AI — clasificador de riesgo OPCIONAL (off por defecto)
# Rol: BACKUP_AI_CLASSIFIER. Nunca genera, cierra ni envía picks.
# ----------------------------------------------------------------------------
FIREWORKS_ENABLED=false
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/gpt-oss-120b

# ----------------------------------------------------------------------------
# Caché de noticias web
# ----------------------------------------------------------------------------
NEWS_CACHE_MINUTES=360

# ----------------------------------------------------------------------------
# Telegram — notificación OPCIONAL e informativa (no envía picks)
# Crea un bot con @BotFather y obtén tu chat_id. Si quedan vacíos, el bot
# simplemente no notifica (no falla).
# ----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
