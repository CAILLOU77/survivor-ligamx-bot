# ============================================================================
# Survivor Liga MX Bot — Plantilla de configuración (.env.example)
# ----------------------------------------------------------------------------
# Copia este archivo a `.env` y rellena tus valores reales:
#     cp .env.example .env
#
# IMPORTANTE:
# - `.env` NUNCA se commitea (está en .gitignore). Solo este `.env.example`.
# - Aquí solo van PLACEHOLDERS, nunca claves reales.
# - El bot es INFORMATIVO: no cierra ni envía picks automáticos. Todo lo de
#   abajo es OPCIONAL; sin claves, cada función degrada sin romperse.
# ============================================================================

# ----------------------------------------------------------------------------
# API web (FastAPI)
# ----------------------------------------------------------------------------
# Clave para los endpoints protegidos (/stats, /history, /alerts/*, ...).
# SIN default público: define una clave fuerte propia (y el MISMO valor como
# secret API_KEY en GitHub Actions, para el workflow de alertas).
API_KEY=cambia-esto-por-una-clave-fuerte-y-secreta
# Base de datos. Postgres en producción (Render); si se deja vacío o se pone una
# ruta, se usa SQLite local automáticamente (data/premium_history.db).
DATABASE_URL=
# URL pública de la API (la usa el notificador de Telegram).
API_BASE=https://survivor-ligamx-bot.onrender.com

# ----------------------------------------------------------------------------
# Momios / mercado — odds-api.io (OPCIONAL, capa de comparación vs el modelo)
# Sin ODDS_API_IO_KEY, la capa queda APAGADA (no-op) y el bot sigue igual.
# El modelo (ESPN + Poisson) es la fuente de verdad.
# ----------------------------------------------------------------------------
ODDS_API_IO_KEY=
# Slug de la liga en odds-api.io (default ya correcto para Liga MX Apertura).
ODDS_API_IO_LIGA=mexico-liga-mx-apertura
# Máx. casas por consulta (el tier gratis permite 2).
ODDS_API_IO_MAX_CASAS=2
# Opcionales (tienen defaults sensatos en el código):
# ODDS_API_IO_BOOKMAKERS=        # forzar casas concretas (coma) en vez de auto
# ODDS_API_IO_VENTANA_DIAS=120   # ventana de fixtures a futuro
# ODDS_API_IO_MAX_EVENTOS=20     # tope de partidos por ciclo

# ----------------------------------------------------------------------------
# Liga MX API (proyecto hermano) — OPCIONAL
# https://ligamx-api.onrender.com  ·  datos públicos del torneo vigente.
# La usa scripts/import_calendario.py para generar data/calendario.json (lo que
# necesita el planificador de temporada). Sin definir nada, usa el default.
# ----------------------------------------------------------------------------
LIGAMX_API_URL=https://ligamx-api.onrender.com
# Timeout por request en segundos (Render free tier puede tardar en despertar).
LIGAMX_API_TIMEOUT=30
# Si es 1/true, fuentes_datos usa esta API como fuente PRIMARIA de resultados
# para el modelo Poisson (útil cuando la temporada ya tiene partidos jugados;
# en pretemporada devuelve vacío y cae a ESPN). Default: apagado.
LIGAMX_API_AS_SOURCE=

# ----------------------------------------------------------------------------
# Telegram — notificación OPCIONAL e informativa (no envía picks)
# Crea un bot con @BotFather y obtén tu chat_id. Vacíos = no notifica (no falla).
# ----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Secreto opcional para el webhook de comandos (/usado, /pick, ...). Si se define,
# Telegram debe enviarlo en el header y el bot lo valida. Genera uno aleatorio.
TELEGRAM_WEBHOOK_SECRET=
